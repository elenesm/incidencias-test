NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=tu_usuario_db
DB_PASSWORD=tu_password_seguro
DB_NAME=incidencias_db

# JWT - usar un string aleatorio largo y seguro (ej: openssl rand -base64 64)
JWT_SECRET=REEMPLAZAR_CON_UN_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=24h
