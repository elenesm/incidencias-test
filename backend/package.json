{
  "name": "api-incidencias",
  "version": "1.0.0",
  "description": "API REST - Sistema de Gestión de Incidencias",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test": "jest --testEnvironment node",
    "migrate": "npx sequelize-cli db:migrate",
    "seed": "npx sequelize-cli db:seed:all",
    "migrate-seed-start": "npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all && node src/index.js",
    "migrate:undo": "npx sequelize-cli db:migrate:undo:all"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.11.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.0",
    "sequelize-cli": "^6.6.2"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2"
  }
}
